{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": false,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "newLine": "lf",

    "baseUrl": ".",
    "paths": {
      "@nova-app/shared": ["./packages/shared/src/index.ts"],
      "@nova-app/shared/*": ["./packages/shared/src/*"],
      "@nova-app/engine": ["./packages/engine/src/index.ts"],
      "@nova-app/engine/*": ["./packages/engine/src/*"],
      "@nova-app/connectors": ["./packages/connectors/src/index.ts"],
      "@nova-app/connectors/*": ["./packages/connectors/src/*"],
      "@nova-app/persistence": ["./packages/persistence/src/index.ts"],
      "@nova-app/persistence/*": ["./packages/persistence/src/*"],
      "@nova-app/cache": ["./packages/cache/src/index.ts"],
      "@nova-app/cache/*": ["./packages/cache/src/*"],
      "@nova-app/risk": ["./packages/risk/src/index.ts"],
      "@nova-app/risk/*": ["./packages/risk/src/*"],
      "@nova-app/alerts": ["./packages/alerts/src/index.ts"],
      "@nova-app/alerts/*": ["./packages/alerts/src/*"],
      "@nova-app/execution": ["./packages/execution/src/index.ts"],
      "@nova-app/execution/*": ["./packages/execution/src/*"],
      "@nova-app/dex": ["./packages/dex/src/index.ts"],
      "@nova-app/dex/*": ["./packages/dex/src/*"],
      "@nova-app/bridge": ["./packages/bridge/src/index.ts"],
      "@nova-app/bridge/*": ["./packages/bridge/src/*"],
      "@nova-app/discovery": ["./packages/discovery/src/index.ts"],
      "@nova-app/discovery/*": ["./packages/discovery/src/*"],
      "@nova-app/resilience": ["./packages/resilience/src/index.ts"],
      "@nova-app/resilience/*": ["./packages/resilience/src/*"],
      "@nova-app/observability": ["./packages/observability/src/index.ts"],
      "@nova-app/observability/*": ["./packages/observability/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next", ".turbo"]
}